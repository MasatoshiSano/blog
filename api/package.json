{
  "name": "blog-api",
  "version": "0.1.0",
  "private": true,
  "description": "Blog admin API - Lambda handlers for auth, posts preview/publish, image presign",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.js --external:@aws-sdk/* --minify",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "@aws-sdk/client-s3": "^3.728.0",
    "@aws-sdk/client-ssm": "^3.728.0",
    "@aws-sdk/s3-request-presigner": "^3.728.0",
    "gray-matter": "^4.0.3",
    "jose": "^5.9.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.150",
    "@types/node": "^22.10.0",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
